# BioLedger environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM API Keys (set at least one) ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# --- LLM model (optional) ---
# Override the default model (openai:gpt-4o). Uses pydantic-ai format: provider:model
# Providers: openai, anthropic, google-gla, google-vertex, groq, ollama
# This also switches all primary task models to the same provider.
# BIOLEDGER_DEFAULT_MODEL=anthropic:claude-sonnet-4-20250514
# BIOLEDGER_DEFAULT_MODEL=google-gla:gemini-2.5-flash

# --- BioLedger settings ---
# BIOLEDGER_HOME_DIR=~/.bioledger
